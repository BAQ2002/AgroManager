<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AgroManager</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/components/topbar/topbar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/components/sidebar/sidebar.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
    <link rel="stylesheet" href="~/components/date-picker/date-picker.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
</head>

@{
    var pageWidth = ViewData["PageMaxWidth"] as string;
    var pageContainerClass = pageWidth switch
    {
        "wide" => "am-page-container am-page-container-wide",
        "full" => "am-page-container am-page-container-full",
        _ => "am-page-container"
    };
}

<body data-current-controller="@ViewContext.RouteData.Values["controller"]">

    <!-- NAVBAR SUPERIOR -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
            <div class="container-fluid">

                <!-- Nome da aplicação -->
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    AgroManager
                </a>

                <!-- Botão Mobile -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Conteúdo Navbar -->
                <div class="collapse navbar-collapse" id="mainNavbar">

                    <!-- Menu esquerdo -->
                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                Início
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Bovine" asp-action="Index">
                                Bovinos
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Swines" asp-action="Index">
                                Suínos
                            </a>
                        </li>

                    </ul>

                    <!-- Botão usuário canto direito -->
                    <div class="d-flex">
                        <a class="btn btn-outline-light" asp-controller="Account" asp-action="Login" title="Conta">
                            <i class="bi bi-person-circle fs-5"></i>
                        </a>
                    </div>

                </div>
            </div>
        </nav>
    </header>

    <div class="am-app-shell">
        <aside class="am-sidebar" aria-label="Menu lateral">
            <nav class="js-am-sidebar-root"></nav>
        </aside>

        <!-- CONTEÚDO PRINCIPAL -->
        <div class="am-sidebar-main">
            <div class="@pageContainerClass mt-4">
                <main role="main">
                    @RenderBody()
                </main>
            </div>

            <!-- FOOTER -->
            <footer class="border-top footer text-muted mt-5">
                <div class="container text-center py-3">
                    &copy; 2026 - AgroManager
                </div>
            </footer>
        </div>
    </div>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/pt.js"></script>
    <script src="~/components/date-picker/date-picker.js" asp-append-version="true"></script>
    <script src="~/components/sidebar/sidebar.js" asp-append-version="true"></script>
    <script id="am-sidebar-config" type="application/json">
        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new
        {
            title = "Navegação",
            sections = new object[]
            {
                new
                {
                    label = "Principal",
                    links = new object[]
                    {
                        new { label = "Início", href = Url.Action("Index", "Home"), controller = "Home" }
                    }
                },
                new
                {
                    label = "Gestão de rebanho",
                    links = new object[]
                    {
                        new { label = "Bovinos", href = Url.Action("Index", "Bovine"), controller = "Bovine" },
                        new { label = "Suínos", href = Url.Action("Index", "Swines"), controller = "Swines" }
                    }
                },
                new
                {
                    label = "Acesso",
                    links = new object[]
                    {
                        new { label = "Conta", href = Url.Action("Login", "Account"), controller = "Account" }
                    }
                }
            }
        }))
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
