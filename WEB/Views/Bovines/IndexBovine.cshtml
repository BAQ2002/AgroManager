@{
    ViewData["Title"] = "Bovines";
    ViewData["PageMaxWidth"] = "wide";
}

@section Styles {
    <link rel="stylesheet" href="~/components/primary-button/primary-button.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/components/data-grid/data-grid.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/components/form-container/form-container.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/components/floating-text-box/floating-text-box.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/components/enum-check-box/enum-check-box.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/components/enum-combo-box/enum-combo-box.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/bovines/IndexBovine.css" asp-append-version="true" />

    <style>
        #ageUnitSelect::after {
            border-right-color: var(--color-white);
            border-bottom-color: var(--color-white);
        }
    </style>
}

<header class="page-header bovines-page-header">
    <div>
        <h1 class="page-title">Bovines</h1>
        <p class="page-subtitle">Lista de bovinos cadastrados no AgroManager.</p>

        <div class="inline-actions">

            <a class="primary-button" href="/">
                <img class="primary-button-svg" src="~/assets/icons/back_icon.svg" alt="" />
                <button-label>Voltar</button-label>
            </a>

            <a class="primary-button" href="/bovines/create">
                <img class="primary-button-svg" src="~/assets/icons/addIcon.svg" alt="" />
                <button-label>Novo Bovine</button-label>
            </a>

        </div>
    </div>
</header>

<div class="bovines-content-layout">
    <section class=" form-container box-shadow-light" id="filtersPanel" aria-labelledby="filtersPanelTitle" style="margin: 8px 0 16px;
                     border-radius: 18px;
                     border: 1px solid var(--color-border);
                     background: var(--color-white);
                     padding: 16px;
                     overflow: visible;
                     width: 100%;">
        
        <div class="form-container-title" id="filtersPanelTitle">
            <img class="form-container-title-icon" src="~/assets/icons/filters.svg" alt="" />
            <label class="form-container-label"> 
                Filtros de pesquisa
            </label>
        </div>

        <div class="form-one-columns">
                        
            <div class="floating-field">
                <input class="floating-field-input" id="filterName" type="text" placeholder=" " data-empty-values="" />
                 <span class="floating-field-label">Nome</span>
            </div>
                        
        </div>

        <div class="form-two-columns">

            <div class="floating-field">
                <div class="enum-check-box" data-filter="Tipo">
                    <button class="floating-field-input" type="button" aria-expanded="false"></button>
                    <div class="enum-check-box-menu" id="filterCattleType">
                        <label><input type="checkbox" value="Unknown" /> Unknown</label>
                        <label><input type="checkbox" value="Beef" /> Beef</label>
                        <label><input type="checkbox" value="Dairy" /> Dairy</label>
                    </div>
                </div>
                <span class="floating-field-label">Tipo</span>
            </div>

            <div class="floating-field">
                <div class="enum-check-box" data-filter="Origem">
                    <button class="floating-field-input" type="button" aria-expanded="false"></button>
                    <div class="enum-check-box-menu" id="filterOrigin">
                        <label><input type="checkbox" value="Unknown" /> Unknown</label>
                        <label><input type="checkbox" value="Born" /> Born</label>
                        <label><input type="checkbox" value="Purchased" /> Purchased</label>
                         <label><input type="checkbox" value="External" /> External</label>
                     </div>
                </div>
                <span class="floating-field-label">Origem</span>
            </div>                  
        </div>

        <div class="form-two-columns">
            <div class="floating-field">
                <div class="enum-check-box" data-filter="Sexo">
                    <button class="floating-field-input" type="button" aria-expanded="false"></button>
                    <div class="enum-check-box-menu" id="filterGender">
                        <label><input type="checkbox" value="Unknown" /> Unknown</label>
                        <label><input type="checkbox" value="Male" /> Male</label>
                        <label><input type="checkbox" value="Female" /> Female</label>
                    </div>
                </div>
                <span class="floating-field-label">Sexo</span>
            </div>

            <div class="floating-field">
                <div class="enum-check-box" data-filter="Estado">
                    <button class="floating-field-input" type="button" aria-expanded="false"></button>
                    <div class="enum-check-box-menu" id="filterMaritalStatus">
                        <label><input type="checkbox" value="Unknown" /> Unknown</label>
                        <label><input type="checkbox" value="Single" /> Single</label>
                        <label><input type="checkbox" value="Pregnant" /> Pregnant</label>
                        <label><input type="checkbox" value="Mother" /> Mother</label>
                    </div>
                </div>
                <span class="floating-field-label">Estado</span>
            </div>

        </div>

        <div class="form-two-columns">

            <div class="floating-field">
                <input class="floating-field-input js-floating-control" id="filterAgeMin" type="number" min="0" placeholder=" " data-empty-values="" />
                <span class="floating-field-label">Idade (mín.)</span>
            </div>

            <div class="floating-field">
                <input class="floating-field-input js-floating-control" id="filterAgeMax" type="number" min="0" placeholder=" " data-empty-values="" />
                <span class="floating-field-label">Idade (máx.)</span>
            </div>

        </div>

        <div class="form-two-columns">

            <div class="floating-field">
                <input class="floating-field-input js-floating-control js-date-picker" id="filterBirthDateMin" type="text" placeholder=" " data-empty-values="" autocomplete="off" />
                <span class="floating-field-label">Nascimento (mín.)</span>
            </div>

            <div class="floating-field">
                <input class="floating-field-input js-floating-control js-date-picker" id="filterBirthDateMax" type="text" placeholder=" " data-empty-values="" autocomplete="off" />
                <span class="floating-field-label">Nascimento (máx.)</span>
            </div>
                        
        </div>

        <button class="primary-button" type="button" style="width: 100%; margin-left: auto" data-action="clear-filters">
            <img class="primary-button-svg" src="~/assets/icons/deleteIcon.svg" alt="" />
            <button-label>Limpar filtros</button-label>
        </button>
       
    </section>
        
    <div class="bovines-records-column">
    <section class="datagrid-wrapper box-shadow-light">

            <div class ="datagrid-toolbar">
                <label for="bovinesPageSize">Registros por página</label>
                <select class="datagrid-page-size" id="bovinesPageSize">
                    <option value="10">10</option>
                    <option value="15" selected>15</option>
                    <option value="20">20</option>
                    <option value="25">25</option>
                </select>
        </div>
        <table class="datagrid">
            
            <thead>
                 <tr>                
                     <th data-sort-key="name">
                         <div class="datagrid-sort-header"><button type="button" class="primary-button datagrid-sort-priority-btn" data-role="priority" aria-label="Prioridade de ordenação de Nome">1°</button><span>Nome</span><button type="button" class="primary-button datagrid-sort-direction-btn" data-role="direction" aria-label="Direção de ordenação de Nome"><img class="primary-button-svg" src="~/assets/icons/filter_by_icon.svg" alt="" /></button></div><div class="enum-combo-box-menu datagrid-sort-menu" data-menu="priority"></div><div class="enum-combo-box-menu datagrid-sort-menu" data-menu="direction"><button class="enum-combo-box-option active" type="button" data-value="asc">Crescente</button><button class="enum-combo-box-option" type="button" data-value="desc">Decrescente</button></div>
                     </th>
                     <th data-sort-key="gender"><div class="datagrid-sort-header"><button type="button" class="primary-button datagrid-sort-priority-btn" data-role="priority" aria-label="Prioridade de ordenação de Sexo"></button><span>Sexo</span><button type="button" class="primary-button datagrid-sort-direction-btn" data-role="direction" aria-label="Direção de ordenação de Sexo"><img class="primary-button-svg" src="~/assets/icons/filter_by_icon.svg" alt="" /></button></div><div class="enum-combo-box-menu datagrid-sort-menu" data-menu="priority"></div><div class="enum-combo-box-menu datagrid-sort-menu" data-menu="direction"><button class="enum-combo-box-option active" type="button" data-value="asc">Crescente</button><button class="enum-combo-box-option" type="button" data-value="desc">Decrescente</button></div></th>
                     <th data-sort-key="origin"><div class="datagrid-sort-header"><button type="button" class="primary-button datagrid-sort-priority-btn" data-role="priority" aria-label="Prioridade de ordenação de Origem"></button><span>Origem</span><button type="button" class="primary-button datagrid-sort-direction-btn" data-role="direction" aria-label="Direção de ordenação de Origem"><img class="primary-button-svg" src="~/assets/icons/filter_by_icon.svg" alt="" /></button></div><div class="enum-combo-box-menu datagrid-sort-menu" data-menu="priority"></div><div class="enum-combo-box-menu datagrid-sort-menu" data-menu="direction"><button class="enum-combo-box-option active" type="button" data-value="asc">Crescente</button><button class="enum-combo-box-option" type="button" data-value="desc">Decrescente</button></div></th>
                     <th data-sort-key="birthDate"><div class="datagrid-sort-header"><button type="button" class="primary-button datagrid-sort-priority-btn" data-role="priority" aria-label="Prioridade de ordenação de Nascimento"></button><span>Nascimento</span><button type="button" class="primary-button datagrid-sort-direction-btn" data-role="direction" aria-label="Direção de ordenação de Nascimento"><img class="primary-button-svg" src="~/assets/icons/filter_by_icon.svg" alt="" /></button></div><div class="enum-combo-box-menu datagrid-sort-menu" data-menu="priority"></div><div class="enum-combo-box-menu datagrid-sort-menu" data-menu="direction"><button class="enum-combo-box-option active" type="button" data-value="asc">Crescente</button><button class="enum-combo-box-option" type="button" data-value="desc">Decrescente</button></div></th>
                     <th data-sort-key="age"><div class="datagrid-sort-header"><button type="button" class="primary-button datagrid-sort-priority-btn" data-role="priority" aria-label="Prioridade de ordenação de Idade"></button><div class="enum-combo-box" id="ageUnitSelect"><span style="color: var(--color-black)"> Idade (<span id="ageUnitLabel">anos</span>)</span><div class="enum-combo-box-menu" id="ageUnitMenu"><button class="enum-combo-box-option active" type="button" data-unit="years">Anos</button><button class="enum-combo-box-option" type="button" data-unit="months">Meses</button><button class="enum-combo-box-option" type="button" data-unit="days">Dias</button></div></div><button type="button" class="primary-button datagrid-sort-direction-btn" data-role="direction" aria-label="Direção de ordenação de Idade"><img class="primary-button-svg" src="~/assets/icons/filter_by_icon.svg" alt="" /></button></div><div class="enum-combo-box-menu datagrid-sort-menu" data-menu="priority"></div><div class="enum-combo-box-menu datagrid-sort-menu" data-menu="direction"><button class="enum-combo-box-option active" type="button" data-value="asc">Crescente</button><button class="enum-combo-box-option" type="button" data-value="desc">Decrescente</button></div></th>
                     <th data-sort-key="maritalStatus"><div class="datagrid-sort-header"><button type="button" class="primary-button datagrid-sort-priority-btn" data-role="priority" aria-label="Prioridade de ordenação de Estado"></button><span>Estado</span><button type="button" class="primary-button datagrid-sort-direction-btn" data-role="direction" aria-label="Direção de ordenação de Estado"><img class="primary-button-svg" src="~/assets/icons/filter_by_icon.svg" alt="" /></button></div><div class="enum-combo-box-menu datagrid-sort-menu" data-menu="priority"></div><div class="enum-combo-box-menu datagrid-sort-menu" data-menu="direction"><button class="enum-combo-box-option active" type="button" data-value="asc">Crescente</button><button class="enum-combo-box-option" type="button" data-value="desc">Decrescente</button></div></th>
                     <th data-sort-key="cattleType"><div class="datagrid-sort-header"><button type="button" class="primary-button datagrid-sort-priority-btn" data-role="priority" aria-label="Prioridade de ordenação de Tipo"></button><span>Tipo</span><button type="button" class="primary-button datagrid-sort-direction-btn" data-role="direction" aria-label="Direção de ordenação de Tipo"><img class="primary-button-svg" src="~/assets/icons/filter_by_icon.svg" alt="" /></button></div><div class="enum-combo-box-menu datagrid-sort-menu" data-menu="priority"></div><div class="enum-combo-box-menu datagrid-sort-menu" data-menu="direction"><button class="enum-combo-box-option active" type="button" data-value="asc">Crescente</button><button class="enum-combo-box-option" type="button" data-value="desc">Decrescente</button></div></th>
                     <th>Ações</th>
                 </tr>
            </thead>
            <tbody id="rows"></tbody>
        </table>
     </section>

            <footer class="footer-info">
                <span>Fonte dos dados: Postgres (Docker) via EF Core.</span>
                <div class="datagrid-pagination-actions" aria-label="Paginação">
                    <button type="button" class="datagrid-page-button" id="bovinesPrevPage" aria-label="Página anterior">‹</button>
                    <div class="datagrid-page-markers" id="bovinesPageInfo" aria-label="Páginas"></div>
                    <button type="button" class="datagrid-page-button" id="bovinesNextPage" aria-label="Próxima página">›</button>
                </div>
                <span id="count">Mostrando 0 de 0 registro(s)</span>
            </footer>
        </div>
</div>

@section Scripts {
    <script src="~/components/enum-check-box/enum-check-box.js" asp-append-version="true"></script>
    <script src="~/components/data-grid/data-grid.js" asp-append-version="true"></script>
    <script src="~/js/pages/bovines/index.js" asp-append-version="true"></script>
}
