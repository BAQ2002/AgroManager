@{
    ViewData["Title"] = "Bovines";
    ViewData["PageMaxWidth"] = "wide";
}

@section Styles {
    <link rel="stylesheet" href="~/css/components/PrimaryButton.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/DataGrid.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/filters-panel.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/FormContainer.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/FloatingTextBox.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/EnumCheckboxSelect.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/EnumSingleSelect.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/bovines/IndexBovine.css" asp-append-version="true" />
}

<header class="page-header bovines-page-header">
    <div>
        <h1 class="page-title">Bovines</h1>
        <p class="page-subtitle">Lista de bovinos cadastrados no AgroManager.</p>

        <div class="am-inline-actions">

            <a class="primary-button" href="/">
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M15 18l-6-6 6-6"></path>
                    <path d="M21 12H9"></path>
                </svg>
                <span>Voltar</span>
            </a>

            <a class="primary-button" href="/bovines/create">
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M12 5v14"></path>
                    <path d="M5 12h14"></path>
                </svg>
                <span>Novo Bovine</span>
            </a>

        </div>
    </div>
</header>

<div class="bovines-content-layout">
        <section id="filtersPanel" class=" filters-panel" aria-labelledby="filtersPanelTitle">
            <fieldset class="filters-fieldset">
                <legend id="filtersPanelTitle" class="filters-legend">Filtros de busca</legend>

                <div class="form-stack filters-form">
                    <div class="form-one-columns">
                        
                        <div class="floating-field">
                            <input id="filterName" type="text" placeholder=" " class="floating-field-input js-floating-control" data-empty-values="" />
                            <span class="floating-field-label">Nome</span>
                        </div>
                        
                    </div>

                    <div class="form-two-columns">

                        <div class="floating-field">
                            <div class="enum-select" data-filter="Tipo">
                                <button type="button" class="floating-field-input" aria-expanded="false"></button>
                                <div class="enum-select-menu" id="filterCattleType">
                                    <label><input type="checkbox" value="Unknown" /> Unknown</label>
                                    <label><input type="checkbox" value="Beef" /> Beef</label>
                                    <label><input type="checkbox" value="Dairy" /> Dairy</label>
                                </div>
                            </div>
                            <span class="floating-field-label">Tipo</span>
                        </div>

                        <div class="floating-field">
                            <div class="enum-select" data-filter="Origem">
                                <button type="button" class="floating-field-input" aria-expanded="false"></button>
                                <div class="enum-select-menu" id="filterOrigin">
                                    <label><input type="checkbox" value="Unknown" /> Unknown</label>
                                    <label><input type="checkbox" value="Born" /> Born</label>
                                    <label><input type="checkbox" value="Purchased" /> Purchased</label>
                                    <label><input type="checkbox" value="External" /> External</label>
                                </div>
                            </div>
                            <span class="floating-field-label">Origem</span>
                        </div>                  
                    </div>

                    <div class="form-two-columns">
                        
                        <div class="floating-field">
                            <div class="enum-select" data-filter="Sexo">
                                <button type="button" class="floating-field-input" aria-expanded="false"></button>
                                <div class="enum-select-menu" id="filterGender">
                                    <label><input type="checkbox" value="Unknown" /> Unknown</label>
                                    <label><input type="checkbox" value="Male" /> Male</label>
                                    <label><input type="checkbox" value="Female" /> Female</label>
                                </div>
                            </div>
                            <span class="floating-field-label">Sexo</span>
                        </div>
                                            
                        <div class="floating-field">
                            <div class="enum-select" data-filter="Estado">
                                <button type="button" class="floating-field-input" aria-expanded="false"></button>
                                <div class="enum-select-menu" id="filterMaritalStatus">
                                    <label><input type="checkbox" value="Unknown" /> Unknown</label>
                                    <label><input type="checkbox" value="Single" /> Single</label>
                                    <label><input type="checkbox" value="Pregnant" /> Pregnant</label>
                                    <label><input type="checkbox" value="Mother" /> Mother</label>
                                </div>
                            </div>
                            <span class="floating-field-label">Estado</span>
                        </div>                   
                    </div>

                    <div class="form-two-columns">

                        <div class="floating-field">
                            <input id="filterAgeMin" type="number" min="0" placeholder=" " class="floating-field-input js-floating-control" data-empty-values="" />
                            <span class="floating-field-label">Idade (mín.)</span>
                        </div>
                                  
                        <div class="floating-field">
                            <input id="filterAgeMax" type="number" min="0" placeholder=" " class="floating-field-input js-floating-control" data-empty-values="" />
                            <span class="floating-field-label">Idade (máx.)</span>
                        </div>                  
                    </div>

                    <div class="form-two-columns">

                        <div class="floating-field">
                            <input id="filterBirthDateMin" type="text" placeholder=" " class="floating-field-input js-floating-control js-date-picker" data-empty-values="" autocomplete="off" />
                            <span class="floating-field-label">Nascimento (mín.)</span>
                        </div>

                        <div class="floating-field">
                            <input id="filterBirthDateMax" type="text" placeholder=" " class="floating-field-input js-floating-control js-date-picker" data-empty-values="" autocomplete="off" />
                            <span class="floating-field-label">Nascimento (máx.)</span>
                        </div>
                    </div>
                </div>

                <div class="filters-actions">
                    <button type="button" class="primary-button" data-action="clear-filters">
                        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                            <path d="M18 6L6 18"></path>
                            <path d="M6 6l12 12"></path>
                        </svg>
                        <span>Limpar filtros</span>
                    </button>
                </div>
            </fieldset>
        </section>

        <div class="bovines-records-column">
            <section class="datagrid-wrapper">
                <table class="datagrid">
                    <thead>
                        <tr>
                            <th>Nome</th>
                            <th>Sexo</th>
                            <th>Origem</th>
                            <th>Nascimento</th>
                            <th>
                                <span class="age-header-select">
                                    <div class="enum-single-select enum-single-select--age-header" id="ageUnitSelect">
                                        <button type="button" class="enum-single-select-trigger" id="ageUnitTrigger" aria-expanded="false" aria-label="Selecionar unidade de idade">
                                            <span class="age-unit-label">Idade (<span id="ageUnitLabel">anos</span>)</span>
                                        </button>
                                        <div class="enum-single-select-menu" id="ageUnitMenu">
                                            <button type="button" class="enum-single-select-option active" data-unit="years">Anos</button>
                                            <button type="button" class="enum-single-select-option" data-unit="months">Meses</button>
                                            <button type="button" class="enum-single-select-option" data-unit="days">Dias</button>
                                        </div>
                                    </div>
                                </span>
                            </th>
                            <th>Estado</th>
                            <th>Tipo</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody id="rows"></tbody>
                </table>
            </section>

            <footer class="footer-info">
                <span>Fonte dos dados: Postgres (Docker) via EF Core.</span>
                <span id="count">0 registro(s) exibidos</span>
            </footer>
        </div>
</div>

@section Scripts {
    <script src="~/js/components/enumCheckboxSelect.js" asp-append-version="true"></script>
    <script src="~/js/pages/bovines/index.js" asp-append-version="true"></script>
}
