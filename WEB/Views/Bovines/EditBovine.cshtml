@model AgroManager.WEB.Controllers.BovineViewModel
@using MODEL
@{
    ViewData["Title"] = "Editar Bovino";
}

@section Styles {
    <link rel="stylesheet" href="~/css/components/PrimaryButton.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/EnumSingleSelect.css" asp-append-version="true" />
}



<div class="am-page-shell">

    <div class="page">
    <header class="page-header">
        <div>
            <h1 class="page-title">Editar Bovine</h1>
            <p class="page-subtitle">Modificar o registro de um bovino no banco de dados.</p>
            <div class="am-inline-actions am-inline-actions-spaced">
                <a class="am-link-plain primary-button" href="/bovines">
                    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M15 18l-6-6 6-6"></path>
                        <path d="M21 12H9"></path>
                    </svg>
                    <span>Voltar</span>
                </a>
            </div>
        </div>
    </header>

    <section class="datagrid-wrapper am-panel-body">
        <form method="post" action="/bovines/edit/@Model.Id" class="am-form-grid">
            @Html.AntiForgeryToken()

            <div class="am-error-text">
                @Html.ValidationSummary(false)
            </div>

            <div class="am-form-columns">
                <div>
                    <label>Nome</label>
                    <input name="Name" value="@Model.Name" class="am-input" />
                    <div class="am-error-text">@Html.ValidationMessageFor(m => m.Name)</div>
                </div>

                <div>
                    <label>Idade</label>
                    <input name="Age" value="@Model.Age" type="number" class="am-input" />
                </div>

                <div>
                    <label>Sexo</label>
                    <div class="enum-single-select js-single-enum-select">
                        <input type="hidden" name="Gender" value="@Model.Gender" />
                        <button type="button" class="enum-single-select-trigger am-input" aria-expanded="false"></button>
                        <div class="enum-single-select-menu">
                        @foreach (var v in Enum.GetValues(typeof(Gender)))
                        {
                            <button type="button" class="enum-single-select-option" data-value="@v" data-label="@v">@v</button>
                        }
                        </div>
                    </div>
                </div>

                <div>
                    <label>Origem</label>
                    <div class="enum-single-select js-single-enum-select">
                        <input type="hidden" name="Origin" value="@Model.Origin" />
                        <button type="button" class="enum-single-select-trigger am-input" aria-expanded="false"></button>
                        <div class="enum-single-select-menu">
                        @foreach (var v in Enum.GetValues(typeof(AcquisitionOrigin)))
                        {
                            <button type="button" class="enum-single-select-option" data-value="@v" data-label="@v">@v</button>
                        }
                        </div>
                    </div>
                </div>

                <div>
                    <label>Nascimento</label>
                    <input name="BirthDate" value="@(Model.BirthDate?.ToString("yyyy-MM-dd"))" type="date"
                           class="am-input" />
                </div>

                <div>
                    <label>Estado civil</label>
                    <div class="enum-single-select js-single-enum-select">
                        <input type="hidden" name="MaritalStatus" value="@Model.MaritalStatus" />
                        <button type="button" class="enum-single-select-trigger am-input" aria-expanded="false"></button>
                        <div class="enum-single-select-menu">
                        <button type="button" class="enum-single-select-option" data-value="" data-label="(vazio)">(vazio)</button>
                        @foreach (var v in Enum.GetValues(typeof(MaritalStatus)))
                        {
                            <button type="button" class="enum-single-select-option" data-value="@v" data-label="@v">@v</button>
                        }
                        </div>
                    </div>
                </div>

                <div>
                    <label>Tipo de gado</label>
                    <div class="enum-single-select js-single-enum-select">
                        <input type="hidden" name="CattleType" value="@Model.CattleType" />
                        <button type="button" class="enum-single-select-trigger am-input" aria-expanded="false"></button>
                        <div class="enum-single-select-menu">
                        <button type="button" class="enum-single-select-option" data-value="" data-label="(vazio)">(vazio)</button>
                        @foreach (var v in Enum.GetValues(typeof(CattleType)))
                        {
                            <button type="button" class="enum-single-select-option" data-value="@v" data-label="@v">@v</button>
                        }
                        </div>
                    </div>
                </div>
            </div>

            <div class="am-form-actions">
                <a class="am-link-plain primary-button" href="/bovines">Cancelar</a>
                <button type="submit" class="am-button-action primary-button">Salvar</button>
            </div>
        </form>
    </section>

    <footer class="footer-info">
        <span>Após salvar, você volta para a listagem.</span>
        <span>AgroManager</span>
    </footer>
</div>
</div>

@section Scripts {
    <script src="~/js/components/enumSingleSelect.js" asp-append-version="true"></script>
}
