@{
    ViewData["Title"] = "Bovines";
}
<link rel="stylesheet" href="~/css/styles.css" />
<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
<link rel="stylesheet" href="~/css/topbar.css" asp-append-version="true" />

<style>
    body {
        display: block;
        padding: 0;
    }

    .am-topbar {
        border-radius: 0;
    }

    .am-page-shell {
        margin: 24px auto;
    }

    .filters-panel {
        margin: 8px 0 16px;
        border-radius: 18px;
        border: 1px solid rgba(148, 163, 184, 0.24);
        background: linear-gradient(145deg, rgba(3, 9, 26, 0.96), rgba(1, 5, 18, 0.98));
        padding: 16px;
        box-shadow: 0 14px 28px rgba(1, 5, 20, 0.4);
        overflow: visible;
    }

    .filters-panel.collapsed .filters-content {
        max-height: 0;
        opacity: 0;
        margin-top: 0;
        overflow: hidden;
        pointer-events: none;
    }

    .filters-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        margin-bottom: 14px;
    }

    .filters-title-group {
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .filters-head h2 {
            margin: 0;
            font-size: 1rem;
            font-weight: 600;
            color: #f8fafc;
        }

    .filters-clear-action {
        cursor: pointer;
    }

    .filters-actions {
        margin-top: 14px;
        display: flex;
        justify-content: flex-end;
    }

    .filters-toggle-control {
        display: inline-flex;
        align-items: center;
        cursor: pointer;
        user-select: none;
    }

    .filters-toggle-input {
        position: absolute;
        width: 1px;
        height: 1px;
        margin: -1px;
        padding: 0;
        overflow: hidden;
        border: 0;
        clip: rect(0 0 0 0);
    }

    .filters-toggle-slider {
        position: relative;
        width: 46px;
        height: 28px;
        border-radius: 999px;
        background: #dc2626;
        transition: background-color 0.22s ease;
        flex: 0 0 auto;
    }

        .filters-toggle-slider::after {
            content: "";
            position: absolute;
            top: 2px;
            left: 2px;
            width: 24px;
            height: 24px;
            border-radius: 50%;
            background: #ffffff;
            box-shadow: 0 3px 8px rgba(15, 23, 42, 0.35);
            transition: transform 0.22s ease;
        }

    .filters-toggle-input:checked + .filters-toggle-slider {
        background: #22c55e;
    }

    .filters-toggle-input:checked + .filters-toggle-slider::after {
        transform: translateX(18px);
    }

    .filters-toggle-input:focus-visible + .filters-toggle-slider {
        outline: 2px solid #5eead4;
        outline-offset: 3px;
    }

    .filters-fieldset {
        border: 0;
        margin: 0;
        padding: 0;
        min-width: 0;
    }

    .filters-fieldset:disabled {
        opacity: 0.55;
    }

    .filters-fieldset:disabled * {
        pointer-events: none;
    }

    .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        border: 0;
        white-space: nowrap;
    }

    .filters-content {
        max-height: 1400px;
        opacity: 1;
        margin-top: 0;
        overflow: visible;
        transition: max-height 0.3s ease, opacity 0.25s ease;
    }

    .filters-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px 12px;
    }

    .filter-range-group {
        grid-column: span 3;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
    }

    .filter-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
        font-size: 0.8rem;
        color: #cbd5e1;
    }

    .filter-label {
        display: block;
        font-size: 0.95rem;
        font-weight: 500;
        line-height: 1.2;
        color: #f8fafc;
    }

    .filter-field input,
    .enum-select-trigger {
        width: 100%;
        height: 42px;
        border: 1px solid rgba(148, 163, 184, 0.8);
        background: #f8fafc;
        color: #020617;
        border-radius: 10px;
        padding: 0 12px;
        font-size: 0.95rem;
    }

        .filter-field input::placeholder {
            color: #64748b;
        }

        .filter-field input:focus,
        .enum-select-trigger:focus {
            outline: none;
            border-color: rgba(45, 212, 191, 0.95);
            box-shadow: 0 0 0 3px rgba(45, 212, 191, 0.24);
        }

    .enum-select {
        position: relative;
    }

    .enum-select-trigger {
        cursor: pointer;
        text-align: left;
        display: flex;
        align-items: center;
        transition: border-color 0.15s ease, box-shadow 0.15s ease;
        padding-right: 34px;
        appearance: none;
        position: relative;
    }

    .enum-select::after {
        content: "";
        position: absolute;
        right: 12px;
        top: 50%;
        width: 8px;
        height: 8px;
        border-right: 2px solid #334155;
        border-bottom: 2px solid #334155;
        transform: translateY(-70%) rotate(45deg);
        pointer-events: none;
        transition: transform 0.15s ease;
    }

    .enum-select.open::after {
        transform: translateY(-30%) rotate(-135deg);
    }

    .enum-select-menu {
        display: none;
        position: absolute;
        z-index: 12;
        top: calc(100% + 6px);
        left: 0;
        right: 0;
        border: 1px solid rgba(148, 163, 184, 0.7);
        border-radius: 10px;
        background: #f8fafc;
        box-shadow: 0 10px 22px rgba(2, 6, 23, 0.28);
        padding: 8px;
        max-height: 190px;
        overflow-y: auto;
    }

    .enum-select.open .enum-select-trigger {
        border-color: rgba(45, 212, 191, 0.95);
        box-shadow: 0 0 0 3px rgba(45, 212, 191, 0.24);
    }

    .enum-select.open .enum-select-menu {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .enum-select-menu label {
        display: flex;
        gap: 6px;
        align-items: center;
        font-size: 0.78rem;
        line-height: 1.1;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        font-weight: 600;
        color: #0f172a;
        padding: 4px 6px;
        border-radius: 8px;
        transition: background-color 0.15s ease;
    }

    .enum-select-menu label input[type="checkbox"] {
        margin: 0;
        width: 14px;
        height: 14px;
        flex: 0 0 auto;
    }

        .enum-select-menu label:hover {
            background: #e2e8f0;
        }



    .age-header-select {
        display: inline-flex;
        align-items: center;
        justify-content: flex-start;
        gap: 6px;
        margin-left: 0;
        padding: 0;
        border-radius: 0;
        background: transparent;
        color: inherit;
    }

    .datagrid td:nth-child(4),
    .datagrid td:nth-child(5) {
        text-align: left;
        font-variant-numeric: tabular-nums;
    }

    .age-unit-select {
        position: relative;
        display: inline-block;
    }

    .age-unit-trigger {
        min-width: 72px;
        height: 24px;
        border: 0;
        background: transparent;
        color: inherit;
        border-radius: 6px;
        padding: 0 14px 0 6px;
        cursor: pointer;
        appearance: none;
        position: relative;
        text-align: left;
        font-size: 0.78rem;
        line-height: 1;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        font-weight: 600;
    }

    .age-unit-select::after {
        content: "";
        position: absolute;
        right: 1px;
        top: 50%;
        width: 6px;
        height: 6px;
        border-right: 1.5px solid currentColor;
        border-bottom: 1.5px solid currentColor;
        transform: translateY(-70%) rotate(45deg);
        pointer-events: none;
        transition: transform 0.15s ease;
    }

    .age-unit-trigger:focus-visible {
        outline: 2px solid rgba(45, 212, 191, 0.95);
        outline-offset: 2px;
    }

    .age-unit-select.open::after {
        transform: translateY(-30%) rotate(-135deg);
    }

    .age-unit-menu {
        display: none;
        position: absolute;
        z-index: 15;
        top: calc(100% + 6px);
        left: 0;
        width: 100%;
        border: 1px solid rgba(148, 163, 184, 0.7);
        border-radius: 10px;
        background: #f8fafc;
        box-shadow: 0 10px 22px rgba(2, 6, 23, 0.28);
        padding: 6px;
    }

    .age-unit-select.open .age-unit-menu {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .age-unit-option {
        border: 0;
        background: transparent;
        text-align: left;
        border-radius: 8px;
        padding: 6px 8px;
        color: #0f172a;
        font-size: 0.78rem;
        line-height: 1.1;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        font-weight: 600;
    }

    .age-unit-option:hover,
    .age-unit-option.active {
        background: #e2e8f0;
    }

    @@media (max-width: 1080px) {
        .filters-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .filter-range-group {
            grid-column: span 2;
        }
    }

    @@media (max-width: 860px) {
        .filters-grid,
        .filter-range-group {
            grid-template-columns: 1fr;
        }

        .filter-range-group {
            grid-column: span 1;
        }
    }
</style>

@await Html.PartialAsync("_Topbar")

<div class="am-page-shell">
    <div class="page">
    <header class="page-header">
        <div>
            <h1 class="page-title">Bovines</h1>
            <p class="page-subtitle">Lista de bovinos cadastrados no AgroManager.</p>
        </div>

        <div style="display:flex; gap:10px; align-items:center;">
            <a class="badge" href="/" style="text-decoration:none;">← Voltar ao início</a>
            <a class="badge" href="/bovines/create" style="text-decoration:none;">+ Novo Bovine</a>
            <span class="badge">AgroManager • Web</span>
        </div>
    </header>

    <section id="filtersPanel" class="datagrid-wrapper filters-panel" aria-label="Filtros de busca de bovinos">
        <div class="filters-head">
            <div class="filters-title-group">
                <label class="filters-toggle-control" for="toggleFilters" aria-controls="filtersContent">
                    <input id="toggleFilters" class="filters-toggle-input" type="checkbox" checked aria-expanded="true" aria-label="Exibir ou ocultar filtros de busca" />
                    <span class="filters-toggle-slider" aria-hidden="true"></span>
                    <span class="sr-only">Ativar filtros de busca</span>
                </label>
                <h2>Filtros de busca</h2>
            </div>
        </div>

        <div id="filtersContent" class="filters-content">
            <fieldset id="filtersFieldset" class="filters-fieldset">
            <div class="filters-grid">
            <label class="filter-field">
                <span class="filter-label">Nome</span>
                <input id="filterName" type="text" placeholder="Ex: Mimosa" />
            </label>

            <div class="filter-field enum-filter">
                <span class="filter-label">Sexo</span>
                <div class="enum-select" data-filter="Sexo">
                    <button type="button" class="enum-select-trigger" aria-expanded="false">Selecionar sexo</button>
                    <div class="enum-select-menu" id="filterGender">
                        <label><input type="checkbox" value="Unknown" /> Unknown</label>
                        <label><input type="checkbox" value="Male" /> Male</label>
                        <label><input type="checkbox" value="Female" /> Female</label>
                    </div>
                </div>
            </div>

            <div class="filter-field enum-filter">
                <span class="filter-label">Origem</span>
                <div class="enum-select" data-filter="Origem">
                    <button type="button" class="enum-select-trigger" aria-expanded="false">Selecionar origem</button>
                    <div class="enum-select-menu" id="filterOrigin">
                        <label><input type="checkbox" value="Unknown" /> Unknown</label>
                        <label><input type="checkbox" value="Born" /> Born</label>
                        <label><input type="checkbox" value="Purchased" /> Purchased</label>
                        <label><input type="checkbox" value="External" /> External</label>
                    </div>
                </div>
            </div>

            <div class="filter-field enum-filter">
                <span class="filter-label">Estado</span>
                <div class="enum-select" data-filter="Estado">
                    <button type="button" class="enum-select-trigger" aria-expanded="false">Selecionar estado</button>
                    <div class="enum-select-menu" id="filterMaritalStatus">
                        <label><input type="checkbox" value="Unknown" /> Unknown</label>
                        <label><input type="checkbox" value="Single" /> Single</label>
                        <label><input type="checkbox" value="Pregnant" /> Pregnant</label>
                        <label><input type="checkbox" value="Mother" /> Mother</label>
                    </div>
                </div>
            </div>

            <div class="filter-field enum-filter">
                <span class="filter-label">Tipo</span>
                <div class="enum-select" data-filter="Tipo">
                    <button type="button" class="enum-select-trigger" aria-expanded="false">Selecionar tipo</button>
                    <div class="enum-select-menu" id="filterCattleType">
                        <label><input type="checkbox" value="Unknown" /> Unknown</label>
                        <label><input type="checkbox" value="Beef" /> Beef</label>
                        <label><input type="checkbox" value="Dairy" /> Dairy</label>
                    </div>
                </div>
            </div>

            <div class="filter-range-group" aria-label="Faixa de nascimento">
                <label class="filter-field">
                    <span class="filter-label">Nascimento (mín.)</span>
                    <input id="filterBirthDateMin" type="date" />
                </label>

                <label class="filter-field">
                    <span class="filter-label">Nascimento (máx.)</span>
                    <input id="filterBirthDateMax" type="date" />
                </label>
            </div>

            <div class="filter-range-group" aria-label="Faixa de idade">
                <label class="filter-field">
                    <span class="filter-label">Idade (mín.)</span>
                    <input id="filterAgeMin" type="number" min="0" placeholder="Ex: 12" />
                </label>

                <label class="filter-field">
                    <span class="filter-label">Idade (máx.)</span>
                    <input id="filterAgeMax" type="number" min="0" placeholder="Ex: 48" />
                </label>
            </div>
            </div>

            <div class="filters-actions">
                <button id="clearFilters" type="button" class="badge filters-clear-action">Limpar filtros</button>
            </div>
            </fieldset>
        </div>
    </section>

    <section class="datagrid-wrapper">
        <table class="datagrid">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Sexo</th>
                    <th>Origem</th>
                    <th>Nascimento</th>
                    <th>
                        <span class="age-header-select">
                            <span>Idade</span>
                            <div class="age-unit-select" id="ageUnitSelect">
                                <button type="button" class="age-unit-trigger" id="ageUnitTrigger" aria-expanded="false" aria-label="Selecionar unidade de idade"></button>
                                <div class="age-unit-menu" id="ageUnitMenu">
                                    <button type="button" class="age-unit-option active" data-unit="years">Anos</button>
                                    <button type="button" class="age-unit-option" data-unit="months">Meses</button>
                                    <button type="button" class="age-unit-option" data-unit="days">Dias</button>
                                </div>
                            </div>
                        </span>
                    </th>
                    <th>Estado</th>
                    <th>Tipo</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody id="rows"></tbody>
        </table>
    </section>

    <footer class="footer-info">
        <span>Fonte dos dados: Postgres (Docker) via EF Core.</span>
        <span id="count">0 registro(s) exibidos</span>
    </footer>
</div>
</div>

<script>
    let allBovines = [];
    let currentAgeUnit = "years";

    function getAgeUnitLabel(unit) {
        if (unit === "months") return "Meses";
        if (unit === "days") return "Dias";
        return "Anos";
    }

    function toDate(value) {
        if (!value) return null;
        const parsed = new Date(value);
        return Number.isNaN(parsed.getTime()) ? null : parsed;
    }

    function getCheckedValues(containerId) {
        return Array.from(document.querySelectorAll(`#${containerId} input[type='checkbox']:checked`)).map(x => x.value.toLowerCase());
    }


    function getAgeByUnit(item) {
        if (currentAgeUnit === "days") return item.ageInDays;
        if (currentAgeUnit === "months") return item.ageInMonths;
        return item.ageInYears ?? item.age;
    }

    function formatAgeByUnit(item) {
        const value = getAgeByUnit(item);
        return value === null || value === undefined || value === "" ? "" : value;
    }

    function renderRows(data) {
        document.getElementById("rows").innerHTML = data.map(x => `
          <tr>
            <td>${x.name ?? ""}</td>
            <td>${x.gender ?? ""}</td>
            <td>${x.origin ?? ""}</td>
            <td>${x.birthDate ?? ""}</td>
            <td>${formatAgeByUnit(x)}</td>
            <td>${x.maritalStatus ?? ""}</td>
            <td>${x.cattleType ?? ""}</td>
            <td><a class="badge" href="/bovines/edit/${x.id}" style="text-decoration:none;">Editar</a></td>
          </tr>
        `).join("");

        document.getElementById("count").innerText = `${data.length} registro(s) exibidos`;
    }

    function applyFilters() {
        const toggleSwitch = document.getElementById("toggleFilters");
        if (toggleSwitch && !toggleSwitch.checked) {
            renderRows(allBovines);
            return;
        }

        const nameFilter = document.getElementById("filterName").value.trim().toLowerCase();
        const genders = getCheckedValues("filterGender");
        const origins = getCheckedValues("filterOrigin");
        const maritalStatuses = getCheckedValues("filterMaritalStatus");
        const cattleTypes = getCheckedValues("filterCattleType");

        const birthDateMin = toDate(document.getElementById("filterBirthDateMin").value);
        const birthDateMax = toDate(document.getElementById("filterBirthDateMax").value);

        const ageMinRaw = document.getElementById("filterAgeMin").value;
        const ageMaxRaw = document.getElementById("filterAgeMax").value;
        const ageMin = ageMinRaw === "" ? null : Number(ageMinRaw);
        const ageMax = ageMaxRaw === "" ? null : Number(ageMaxRaw);

        const filtered = allBovines.filter(x => {
            const name = (x.name ?? "").toLowerCase();
            const gender = (x.gender ?? "").toLowerCase();
            const origin = (x.origin ?? "").toLowerCase();
            const maritalStatus = (x.maritalStatus ?? "").toLowerCase();
            const cattleType = (x.cattleType ?? "").toLowerCase();
            const birthDate = toDate(x.birthDate);
            const ageRaw = getAgeByUnit(x);
            const age = ageRaw === null || ageRaw === undefined || ageRaw === "" ? null : Number(ageRaw);

            if (nameFilter && !name.includes(nameFilter)) return false;
            if (genders.length && !genders.includes(gender)) return false;
            if (origins.length && !origins.includes(origin)) return false;
            if (maritalStatuses.length && !maritalStatuses.includes(maritalStatus)) return false;
            if (cattleTypes.length && !cattleTypes.includes(cattleType)) return false;

            if (birthDateMin && (!birthDate || birthDate < birthDateMin)) return false;
            if (birthDateMax && (!birthDate || birthDate > birthDateMax)) return false;

            if (ageMin !== null && (age === null || age < ageMin)) return false;
            if (ageMax !== null && (age === null || age > ageMax)) return false;

            return true;
        });

        renderRows(filtered);
    }

    function wireFilters() {
        const selectors = [
            "#filterName",
            "#filterBirthDateMin",
            "#filterBirthDateMax",
            "#filterAgeMin",
            "#filterAgeMax",
            "#filterGender input[type='checkbox']",
            "#filterOrigin input[type='checkbox']",
            "#filterMaritalStatus input[type='checkbox']",
            "#filterCattleType input[type='checkbox']"
        ];

        selectors
            .flatMap(selector => Array.from(document.querySelectorAll(selector)))
            .forEach(element => element.addEventListener("input", applyFilters));

        wireEnumSelects();
        wireAgeUnitSelect();
        wireFiltersPanelToggle();

        document.getElementById("clearFilters").addEventListener("click", () => {
            document.getElementById("filterName").value = "";
            document.getElementById("filterBirthDateMin").value = "";
            document.getElementById("filterBirthDateMax").value = "";
            document.getElementById("filterAgeMin").value = "";
            document.getElementById("filterAgeMax").value = "";

            document.querySelectorAll(".enum-select-menu input[type='checkbox']").forEach(x => x.checked = false);
            updateEnumSelectLabels();

            applyFilters();
        });
    }


    function wireAgeUnitSelect() {
        const select = document.getElementById("ageUnitSelect");
        const trigger = document.getElementById("ageUnitTrigger");
        const options = Array.from(select.querySelectorAll(".age-unit-option"));

        trigger.textContent = getAgeUnitLabel(currentAgeUnit);

        trigger.addEventListener("click", (event) => {
            event.stopPropagation();
            const isOpen = select.classList.contains("open");
            select.classList.toggle("open", !isOpen);
            trigger.setAttribute("aria-expanded", (!isOpen).toString());
        });

        options.forEach(option => {
            option.addEventListener("click", () => {
                currentAgeUnit = option.dataset.unit;
                options.forEach(item => item.classList.remove("active"));
                option.classList.add("active");
                trigger.textContent = getAgeUnitLabel(currentAgeUnit);
                select.classList.remove("open");
                trigger.setAttribute("aria-expanded", "false");
                applyFilters();
            });
        });

        document.addEventListener("click", () => {
            select.classList.remove("open");
            trigger.setAttribute("aria-expanded", "false");
        });
    }

    function wireFiltersPanelToggle() {
        const toggleSwitch = document.getElementById("toggleFilters");
        const filtersPanel = document.getElementById("filtersPanel");
        const filtersFieldset = document.getElementById("filtersFieldset");
        const clearFiltersButton = document.getElementById("clearFilters");

        const syncFiltersState = () => {
            const isEnabled = toggleSwitch.checked;
            filtersPanel.classList.toggle("collapsed", !isEnabled);
            filtersFieldset.disabled = !isEnabled;
            clearFiltersButton.disabled = !isEnabled;
            toggleSwitch.setAttribute("aria-expanded", isEnabled.toString());
            applyFilters();
        };

        toggleSwitch.addEventListener("change", syncFiltersState);
        syncFiltersState();
    }

    function updateEnumSelectLabel(selectElement) {
        const trigger = selectElement.querySelector(".enum-select-trigger");
        const checked = selectElement.querySelectorAll("input[type='checkbox']:checked").length;

        if (checked === 0) {
            trigger.textContent = `Selecionar ${selectElement.dataset.filter.toLowerCase()}`;
            return;
        }

        trigger.textContent = checked === 1 ? "1 selecionado" : `${checked} selecionados`;
    }

    function updateEnumSelectLabels() {
        document.querySelectorAll(".enum-select").forEach(updateEnumSelectLabel);
    }

    function wireEnumSelects() {
        document.querySelectorAll(".enum-select").forEach(selectElement => {
            const trigger = selectElement.querySelector(".enum-select-trigger");

            selectElement.addEventListener("click", (event) => {
                event.stopPropagation();
            });

            trigger.addEventListener("click", (event) => {
                event.stopPropagation();
                const isOpen = selectElement.classList.contains("open");

                document.querySelectorAll(".enum-select.open").forEach(item => {
                    item.classList.remove("open");
                    item.querySelector(".enum-select-trigger").setAttribute("aria-expanded", "false");
                });

                if (!isOpen) {
                    selectElement.classList.add("open");
                    trigger.setAttribute("aria-expanded", "true");
                }
            });

            selectElement.querySelectorAll("input[type='checkbox']").forEach(checkbox => {
                checkbox.addEventListener("change", () => updateEnumSelectLabel(selectElement));
            });

            updateEnumSelectLabel(selectElement);
        });

        document.addEventListener("click", () => {
            document.querySelectorAll(".enum-select.open").forEach(selectElement => {
                selectElement.classList.remove("open");
                selectElement.querySelector(".enum-select-trigger").setAttribute("aria-expanded", "false");
            });
        });
    }

    async function load() {
        const res = await fetch("/api/bovines");
        allBovines = await res.json();
        renderRows(allBovines);
    }

    wireFilters();
    load();
</script>
