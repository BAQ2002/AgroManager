@model AgroManager.WEB.Controllers.BovineViewModel
@using MODEL
@{
    ViewData["Title"] = "Novo Bovine";
}


@section Styles {
    <link rel="stylesheet" href="~/css/components/PrimaryButton.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/FloatingTextBox.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/EnumComboBox.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/MainContainer.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/components/enumComboBox.js" asp-append-version="true"></script>
    <script src="~/js/pages/bovines/create.js" asp-append-version="true"></script>
}

<div class="main-container">
    <header class="main-container-header">
        <div>
            <title-label class="main-container-title">Novo Bovine</title-label>
            <p class="main-container-subtitle">Criar um registro de um bovino no banco de dados.</p>
            <div class="am-inline-actions">
                <a class="primary-button" href="/bovines">
                    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M15 18l-6-6 6-6"></path>
                        <path d="M21 12H9"></path>
                    </svg>
                    <button-label>Voltar</button-label>
                </a>
            </div>
        </div>
    </header>
    
    <form class="form-container" method="post" action="/bovines/create" style="padding: 16px">
        @Html.AntiForgeryToken()

        <div class="am-form-columns">

            <div>
                <div class="floating-field">
                    <input class="floating-field-input js-floating-control" name="Name" value="@Model.Name" placeholder=" " data-empty-values="" />
                    <label class="floating-field-label">Nome</label>
                </div>
                <div class="error-description-label">@Html.ValidationMessageFor(m => m.Name)</div>
            </div>

            <div>
                <div class="floating-field">
                    <div class="enum-combo-box">
                        <input class="js-floating-control" type="hidden" name="Gender" value="@Model.Gender" data-empty-values="Unknown" />
                        <button class="floating-field-input" type="button" aria-expanded="false"></button>
                        <div class="enum-combo-box-menu">
                        @foreach (var v in Enum.GetValues(typeof(Gender)))
                        {
                            <button class="enum-combo-box-option" type="button" data-value="@v" data-label="@v">@v</button>
                        }
                        </div>
                    </div>
                        <label class="floating-field-label">Sexo</label>
                    </div>
                    <div class="error-description-label">@Html.ValidationMessageFor(m => m.Gender)</div>
            </div>

            <div>
                <div class="floating-field">
                            <div class="enum-combo-box">
                        <input class="js-floating-control" type="hidden" name="Origin" value="@Model.Origin" data-empty-values="Unknown" />
                        <button class="floating-field-input" type="button" aria-expanded="false"></button>
                        <div class="enum-combo-box-menu">
                        @foreach (var v in Enum.GetValues(typeof(AcquisitionOrigin)))
                        {
                            <button class="enum-combo-box-option" type="button" data-value="@v" data-label="@v">@v</button>
                        }
                        </div>
                        </div>
                        <label class="floating-field-label">Origem</label>
                    </div>
                    <div class="error-description-label">@Html.ValidationMessageFor(m => m.Origin)</div>
            </div>

            <div>
                <div class="floating-field">
                    <input class="floating-field-input js-floating-control" name="BirthDate" value="@(Model.BirthDate?.ToString("yyyy-MM-dd"))" type="date" placeholder=" " data-empty-values="" />
                    <label class="floating-field-label">Nascimento</label>
                </div>
                <div class="error-description-label">@Html.ValidationMessageFor(m => m.BirthDate)</div>
            </div>

            <div>
                <div class="floating-field">
                        <div class="enum-combo-box">
                    <input class="js-floating-control" type="hidden" name="MaritalStatus" value="@Model.MaritalStatus" data-empty-values=",Unknown" />
                    <button class="floating-field-input" type="button" aria-expanded="false"></button>
                    <div class="enum-combo-box-menu">
                    @foreach (var v in Enum.GetValues(typeof(MaritalStatus)))
                    {
                        <button class="enum-combo-box-option" type="button" data-value="@v" data-label="@v">@v</button>
                    }
                    </div>
                    </div>
                    <label class="floating-field-label">Estado civil</label>
                </div>
                <div class="error-description-label">@Html.ValidationMessageFor(m => m.MaritalStatus)</div>
            </div>

            <div>
                <div class="floating-field">
                        <div class="enum-combo-box">
                    <input class="js-floating-control" type="hidden" name="CattleType" value="@Model.CattleType" data-empty-values=",Unknown" />
                    <button class="floating-field-input" type="button" aria-expanded="false"></button>
                    <div class="enum-combo-box-menu">
                    @foreach (var v in Enum.GetValues(typeof(CattleType)))
                    {
                        <button class="enum-combo-box-option" type="button" data-value="@v" data-label="@v">@v</button>
                    }
                    </div>
                    </div>
                    <label class="floating-field-label">Tipo de gado</label>
                </div>
                <div class="error-description-label">@Html.ValidationMessageFor(m => m.CattleType)</div>
            </div>
        </div>

        <div class="am-form-actions">
            <a class="primary-button" href="/bovines">Cancelar</a>
            <button class="primary-button" type="submit">Salvar</button>
        </div>
    </form>

    <footer class="footer-info">
        <span>Após salvar, você volta para a listagem.</span>
        <span>AgroManager</span>
    </footer>  
</div>

