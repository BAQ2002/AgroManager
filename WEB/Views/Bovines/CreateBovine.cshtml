@model AgroManager.WEB.Controllers.BovineViewModel
@using MODEL
@{
    ViewData["Title"] = "Novo Bovine";
}


@section Styles {
    <link rel="stylesheet" href="~/css/components/FloatingTextBox.css" asp-append-version="true" />
}





<div class="am-page-shell">
    <div class="page">
    <header class="page-header">
        <div>
            <h1 class="page-title">Novo Bovine</h1>
            <p class="page-subtitle">Cadastro de um bovino no banco de dados.</p>
        </div>

        <a class="badge am-link-plain" href="/bovines">← Voltar</a>
    </header>

    <section class="datagrid-wrapper am-panel-body">
        <form method="post" action="/bovines/create" class="am-form-grid">
            @Html.AntiForgeryToken()

            <div class="am-form-columns">
                <div>
                    <div class="floating-field">
                        <input name="Name" value="@Model.Name" placeholder=" " class="floating-field-input js-floating-control" data-empty-values="" />
                        <label class="floating-field-label">Nome</label>
                    </div>
                    <div class="am-error-text">@Html.ValidationMessageFor(m => m.Name)</div>
                </div>

                <div>
                    <div class="floating-field">
                        <select name="Gender" class="floating-field-input js-floating-control" data-empty-values="Unknown">
                        @foreach (var v in Enum.GetValues(typeof(Gender)))
                        {
                            <option value="@v" selected="@(Equals(Model.Gender, v) ? "selected" : null)">@v</option>
                        }
                        </select>
                        <label class="floating-field-label">Sexo</label>
                    </div>
                    <div class="am-error-text">@Html.ValidationMessageFor(m => m.Gender)</div>
                </div>

                <div>
                    <div class="floating-field">
                        <select name="Origin" class="floating-field-input js-floating-control" data-empty-values="Unknown">
                        @foreach (var v in Enum.GetValues(typeof(AcquisitionOrigin)))
                        {
                            <option value="@v" selected="@(Equals(Model.Origin, v) ? "selected" : null)">@v</option>
                        }
                        </select>
                        <label class="floating-field-label">Origem</label>
                    </div>
                    <div class="am-error-text">@Html.ValidationMessageFor(m => m.Origin)</div>
                </div>

                <div>
                    <div class="floating-field">
                        <input name="BirthDate" value="@(Model.BirthDate?.ToString("yyyy-MM-dd"))" type="date" placeholder=" " class="floating-field-input js-floating-control" data-empty-values="" />
                        <label class="floating-field-label">Nascimento</label>
                    </div>
                    <div class="am-error-text">@Html.ValidationMessageFor(m => m.BirthDate)</div>
                </div>

                <div>
                    <div class="floating-field">
                        <select name="MaritalStatus" class="floating-field-input js-floating-control" data-empty-values=",Unknown">
                        <option value="">(vazio)</option>
                        @foreach (var v in Enum.GetValues(typeof(MaritalStatus)))
                        {
                            <option value="@v" selected="@(Model.MaritalStatus.HasValue && Equals(Model.MaritalStatus.Value, v) ? "selected" : null)">@v</option>
                        }
                        </select>
                        <label class="floating-field-label">Estado civil</label>
                    </div>
                    <div class="am-error-text">@Html.ValidationMessageFor(m => m.MaritalStatus)</div>
                </div>

                <div>
                    <div class="floating-field">
                        <select name="CattleType" class="floating-field-input js-floating-control" data-empty-values=",Unknown">
                        <option value="">(vazio)</option>
                        @foreach (var v in Enum.GetValues(typeof(CattleType)))
                        {
                            <option value="@v" selected="@(Model.CattleType.HasValue && Equals(Model.CattleType.Value, v) ? "selected" : null)">@v</option>
                        }
                        </select>
                        <label class="floating-field-label">Tipo de gado</label>
                    </div>
                    <div class="am-error-text">@Html.ValidationMessageFor(m => m.CattleType)</div>
                </div>
            </div>

            <div class="am-form-actions">
                <a class="badge am-link-plain" href="/bovines">Cancelar</a>
                <button type="submit" class="badge am-button-action">Salvar</button>
            </div>
        </form>
    </section>

    <footer class="footer-info">
        <span>Após salvar, você volta para a listagem.</span>
        <span>AgroManager</span>
    </footer>
</div>

@section Scripts {
<script src="~/js/pages/bovines/create.js" asp-append-version="true"></script>
}
</div>
