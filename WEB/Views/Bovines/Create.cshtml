@model AgroManager.WEB.Controllers.BovineViewModel
@using MODEL
@{
    ViewData["Title"] = "Novo Bovine";
}

<link rel="stylesheet" href="~/css/styles.css" />
<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
<link rel="stylesheet" href="~/css/topbar.css" asp-append-version="true" />

<style>
    .floating-field {
        position: relative;
    }

    .floating-field-input {
        width: 100%;
        padding: 16px 10px 10px;
        border-radius: 10px;
        border: 1px solid #d1d5db;
        background: transparent;
    }

    .floating-field-label {
        position: absolute;
        left: 10px;
        top: 50%;
        transform: translateY(-50%);
        background: #fff;
        padding: 0 4px;
        color: #6b7280;
        transition: all 0.2s ease;
        pointer-events: none;
    }

    .floating-field:focus-within .floating-field-label,
    .floating-field.filled .floating-field-label,
    .floating-field-input:not(:placeholder-shown) + .floating-field-label {
        top: 0;
        transform: translateY(-50%);
        font-size: 12px;
        color: #374151;
    }
</style>


@await Html.PartialAsync("_Topbar")

<div class="am-page-shell">
    <div class="page">
    <header class="page-header">
        <div>
            <h1 class="page-title">Novo Bovine</h1>
            <p class="page-subtitle">Cadastro de um bovino no banco de dados.</p>
        </div>

        <a class="badge" href="/bovines" style="text-decoration:none;">← Voltar</a>
    </header>

    <section class="datagrid-wrapper" style="padding: 16px;">
        <form method="post" action="/bovines/create" style="display:flex; flex-direction:column; gap:12px;">
            @Html.AntiForgeryToken()

            <div style="display:grid; grid-template-columns: 1fr 1fr; gap:12px;">
                <div>
                    <div class="floating-field">
                        <input name="Name" value="@Model.Name" placeholder=" " class="floating-field-input" />
                        <label class="floating-field-label">Nome</label>
                    </div>
                    <div style="color:#fca5a5;">@Html.ValidationMessageFor(m => m.Name)</div>
                </div>

                <div>
                    <div class="floating-field">
                        <select name="Gender" class="floating-field-input js-floating-select">
                        @foreach (var v in Enum.GetValues(typeof(Gender)))
                        {
                            <option value="@v" selected="@(Equals(Model.Gender, v) ? "selected" : null)">@v</option>
                        }
                        </select>
                        <label class="floating-field-label">Sexo</label>
                    </div>
                    <div style="color:#fca5a5;">@Html.ValidationMessageFor(m => m.Gender)</div>
                </div>

                <div>
                    <div class="floating-field">
                        <select name="Origin" class="floating-field-input js-floating-select">
                        @foreach (var v in Enum.GetValues(typeof(AcquisitionOrigin)))
                        {
                            <option value="@v" selected="@(Equals(Model.Origin, v) ? "selected" : null)">@v</option>
                        }
                        </select>
                        <label class="floating-field-label">Origem</label>
                    </div>
                    <div style="color:#fca5a5;">@Html.ValidationMessageFor(m => m.Origin)</div>
                </div>

                <div>
                    <div class="floating-field">
                        <input name="BirthDate" value="@(Model.BirthDate?.ToString("yyyy-MM-dd"))" type="date" placeholder=" " class="floating-field-input" />
                        <label class="floating-field-label">Nascimento</label>
                    </div>
                    <div style="color:#fca5a5;">@Html.ValidationMessageFor(m => m.BirthDate)</div>
                </div>

                <div>
                    <div class="floating-field">
                        <select name="MaritalStatus" class="floating-field-input js-floating-select">
                        <option value="">(vazio)</option>
                        @foreach (var v in Enum.GetValues(typeof(MaritalStatus)))
                        {
                            <option value="@v" selected="@(Model.MaritalStatus.HasValue && Equals(Model.MaritalStatus.Value, v) ? "selected" : null)">@v</option>
                        }
                        </select>
                        <label class="floating-field-label">Estado civil</label>
                    </div>
                    <div style="color:#fca5a5;">@Html.ValidationMessageFor(m => m.MaritalStatus)</div>
                </div>

                <div>
                    <div class="floating-field">
                        <select name="CattleType" class="floating-field-input js-floating-select">
                        <option value="">(vazio)</option>
                        @foreach (var v in Enum.GetValues(typeof(CattleType)))
                        {
                            <option value="@v" selected="@(Model.CattleType.HasValue && Equals(Model.CattleType.Value, v) ? "selected" : null)">@v</option>
                        }
                        </select>
                        <label class="floating-field-label">Tipo de gado</label>
                    </div>
                    <div style="color:#fca5a5;">@Html.ValidationMessageFor(m => m.CattleType)</div>
                </div>
            </div>

            <div style="display:flex; gap:10px; justify-content:flex-end; margin-top: 8px;">
                <a class="badge" href="/bovines" style="text-decoration:none;">Cancelar</a>
                <button type="submit" class="badge" style="cursor:pointer;">Salvar</button>
            </div>
        </form>
    </section>

    <footer class="footer-info">
        <span>Após salvar, você volta para a listagem.</span>
        <span>AgroManager</span>
    </footer>
</div>

<script>
    document.querySelectorAll(".js-floating-select").forEach((element) => {
        const field = element.closest(".floating-field");

        const syncFilledState = () => {
            field.classList.toggle("filled", element.value !== "");
        };

        element.addEventListener("change", syncFilledState);
        syncFilledState();
    });
</script>
</div>
