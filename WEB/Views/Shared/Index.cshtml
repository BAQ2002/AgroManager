@{
    ViewData["Title"] = "Início";
}


@section Styles {
    <link rel="stylesheet" href="~/css/pages/shared/index.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/components/card/card.css" asp-append-version="true" />

}



<div class="home-shell">


    <main class="hero">
        <h1>Bem-vindo ao AgroManager</h1>
        <p>
            Centralize a operação pecuária em um painel moderno para monitorar animais e lotes.
            Escolha um módulo para começar.
        </p>

        <section class="cards-grid" aria-label="Módulos de gerenciamento">
            <a class="feature-card" asp-controller="bovines" asp-action="Index">
                <span class="feature-icon" aria-hidden="true">
                    <svg class="feature-icon-svg" viewBox="0 0 64 64" role="img" focusable="false">
                        <path d="M18 26c0-8 6-14 14-14s14 6 14 14" />
                        <path d="M12 30c0-3 2-5 5-5h30c3 0 5 2 5 5v8c0 2-1 4-3 5l-7 4v5h-7v-5h-6v5h-7v-5l-7-4c-2-1-3-3-3-5z" />
                        <circle cx="24" cy="34" r="2" fill="currentColor" stroke="none" />
                        <circle cx="40" cy="34" r="2" fill="currentColor" stroke="none" />
                        <path d="M20 24l-6-8" />
                        <path d="M44 24l6-8" />
                        <path d="M28 40h8" />
                    </svg>
                </span>
                <h2>Gerenciar Bovinos</h2>
                <p>Cadastro completo, consulta de dados e acompanhamento do rebanho bovino.</p>
                <span class="tag">Abrir módulo <i class="bi bi-arrow-right-short"></i></span>
            </a>

            <a class="feature-card" asp-controller="Swines" asp-action="Index">
                <span class="feature-icon" aria-hidden="true">
                    <svg class="feature-icon-svg" viewBox="0 0 64 64" role="img" focusable="false">
                        <path d="M18 28c0-7 6-12 14-12s14 5 14 12" />
                        <path d="M14 31c0-3 2-5 5-5h26c3 0 5 2 5 5v8c0 2-1 4-3 5l-6 3v5h-6v-4h-6v4h-6v-5l-6-3c-2-1-3-3-3-5z" />
                        <circle cx="27" cy="35" r="2" fill="currentColor" stroke="none" />
                        <circle cx="37" cy="35" r="2" fill="currentColor" stroke="none" />
                        <path d="M27 23l-4-6" />
                        <path d="M37 23l4-6" />
                        <path d="M28 41h8" />
                    </svg>
                </span>
                <h2>Gerenciar Suínos</h2>
                <p>Organize os suínos por status, origem e evolução produtiva.</p>
                <span class="tag">Abrir módulo <i class="bi bi-arrow-right-short"></i></span>
            </a>

            <a class="feature-card" asp-controller="Batch" asp-action="Index">
                <span class="feature-icon"><i class="bi bi-diagram-3"></i></span>
                <h2>Gerenciar Lotes</h2>
                <p>Visualize e administre lotes para otimizar alocação e manejo no dia a dia.</p>
                <span class="tag">Abrir módulo <i class="bi bi-arrow-right-short"></i></span>
            </a>
        </section>
    </main>
</div>
