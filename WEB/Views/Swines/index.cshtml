@{
ViewData["Title"] = "Swines";
}

@section Styles {
<link rel="stylesheet" href="~/components/data-grid/data-grid.css" asp-append-version="true" />
}


<div class="page-shell">

    <div class="page">
    <header class="page-header">
        <div>
            <h1 class="page-title">Swines</h1>
            <p class="page-subtitle">Lista de suínos cadastrados no AgroManager.</p>
        </div>

        <div class="inline-actions">
                <a class="link-p lainprimary-button" href="/swines/create">+ Novo Swine</a>
        </div>
    </header>

    <section class="datagrid-wrapper">
        <div class="datagrid-toolbar">
            <label for="swinesPageSize">Registros por página</label>
            <select class="datagrid-page-size" id="swinesPageSize">
                <option value="10">10</option>
                <option value="25" selected>25</option>
                <option value="50">50</option>
                <option value="100">100</option>
            </select>
        </div>

        <table class="datagrid">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Sexo</th>
                        <th>Origem</th>
                        <th>Nascimento</th>
                        <th>Idade</th>
                        <th>Tipo</th>
                    </tr>
                </thead>
                <tbody id="rows"></tbody>
            </table>
    </section>

    <footer class="footer-info">
        <span>Fonte dos dados: Postgres (Docker) via EF Core.</span>
        <div class="datagrid-pagination-actions" aria-label="Paginação">
            <button type="button" class="datagrid-page-button" id="swinesPrevPage">Anterior</button>
            <button type="button" class="datagrid-page-button" id="swinesNextPage">Próxima</button>
        </div>
        <span id="swinesPageInfo">Página 1 de 1</span>
        <span id="count">Mostrando 0 de 0 registro(s)</span>
    </footer>
</div>
</div>

@section Scripts {
<script src="~/components/data-grid/data-grid.js" asp-append-version="true"></script>
<script src="~/js/pages/swines/index.js" asp-append-version="true"></script>
}
