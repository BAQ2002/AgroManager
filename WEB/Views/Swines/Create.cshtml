@model AgroManager.WEB.Controllers.SwineViewModel
@using MODEL
@{
    ViewData["Title"] = "Novo Swine";
}



<div class="page-shell">

    <div class="page">
    <header class="page-header">
        <div>
            <h1 class="page-title">Novo Swine</h1>
            <p class="page-subtitle">Cadastro de um suíno no banco de dados.</p>
        </div>

            <a class="link-plain primary-button" href="/swines">← Voltar</a>
    </header>

    <section class="datagrid-wrapper panel-body">
        <form class="form-grid" method="post" action="/swines/create">
            @Html.AntiForgeryToken()

            <div class="error-description-label">
                @Html.ValidationSummary(false)
            </div>

            <div class="form-columns">
                <div>
                    <label>Nome</label>
                    <input class="input" name="Name" value="@Model.Name" />
                    <div class="error-description-label">@Html.ValidationMessageFor(m => m.Name)</div>
                </div>

                <div>
                    <label>Idade</label>
                    <input class="input" name="Age" value="@Model.Age" type="number" />
                </div>

                <div>
                    <label>Sexo</label>
                    <select class="input" name="Gender">
                        @foreach (var v in Enum.GetValues(typeof(Gender)))
                        {
                            <option value="@v" selected="@(Equals(Model.Gender, v) ? "selected" : null)">@v</option>
                        }
                    </select>
                </div>

                <div>
                    <label>Origem</label>
                    <select class="input" name="Origin">
                        @foreach (var v in Enum.GetValues(typeof(AcquisitionOrigin)))
                        {
                            <option value="@v" selected="@(Equals(Model.Origin, v) ? "selected" : null)">@v</option>
                        }
                    </select>
                </div>

                <div>
                    <label>Nascimento</label>
                    <input class="input js-date-picker" name="BirthDate" value="@(Model.BirthDate?.ToString("yyyy-MM-dd"))" type="text" autocomplete="off" />
                </div>

                <div>
                    <label>Tipo (PorcType)</label>
                    <select class="input" name="PorcType">
                        <option value="">(vazio)</option>
                        @foreach (var v in Enum.GetValues(typeof(PorcType)))
                        {
                            <option value="@v" selected="@(Model.PorcType.HasValue && Equals(Model.PorcType.Value, v) ? "selected" : null)">@v</option>
                        }
                    </select>
                </div>
            </div>

            <div class="form-actions">
                    <a class="link-plain primary-button" href="/swines">Cancelar</a>
                    <button class="primary-button" type="submit">Salvar</button>
            </div>
        </form>
    </section>

    <footer class="footer-info">
        <span>Após salvar, você volta para a listagem.</span>
        <span>AgroManager</span>
    </footer>
</div>
</div>
