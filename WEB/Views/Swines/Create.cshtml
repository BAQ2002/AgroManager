@model AgroManager.WEB.Controllers.SwineViewModel
@using MODEL
@{
    ViewData["Title"] = "Novo Swine";
}



<div class="am-page-shell">

    <div class="page">
    <header class="page-header">
        <div>
            <h1 class="page-title">Novo Swine</h1>
            <p class="page-subtitle">Cadastro de um suíno no banco de dados.</p>
        </div>

        <a class="badge am-link-plain" href="/swines">← Voltar</a>
    </header>

    <section class="datagrid-wrapper am-panel-body">
        <form method="post" action="/swines/create" class="am-form-grid">
            @Html.AntiForgeryToken()

            <div class="am-error-text">
                @Html.ValidationSummary(false)
            </div>

            <div class="am-form-columns">
                <div>
                    <label>Nome</label>
                    <input name="Name" value="@Model.Name" class="am-input" />
                    <div class="am-error-text">@Html.ValidationMessageFor(m => m.Name)</div>
                </div>

                <div>
                    <label>Idade</label>
                    <input name="Age" value="@Model.Age" type="number" class="am-input" />
                </div>

                <div>
                    <label>Sexo</label>
                    <select name="Gender" class="am-input">
                        @foreach (var v in Enum.GetValues(typeof(Gender)))
                        {
                            <option value="@v" selected="@(Equals(Model.Gender, v) ? "selected" : null)">@v</option>
                        }
                    </select>
                </div>

                <div>
                    <label>Origem</label>
                    <select name="Origin" class="am-input">
                        @foreach (var v in Enum.GetValues(typeof(AcquisitionOrigin)))
                        {
                            <option value="@v" selected="@(Equals(Model.Origin, v) ? "selected" : null)">@v</option>
                        }
                    </select>
                </div>

                <div>
                    <label>Nascimento</label>
                    <input name="BirthDate" value="@(Model.BirthDate?.ToString("yyyy-MM-dd"))" type="date"
                           class="am-input" />
                </div>

                <div>
                    <label>Tipo (PorcType)</label>
                    <select name="PorcType" class="am-input">
                        <option value="">(vazio)</option>
                        @foreach (var v in Enum.GetValues(typeof(PorcType)))
                        {
                            <option value="@v" selected="@(Model.PorcType.HasValue && Equals(Model.PorcType.Value, v) ? "selected" : null)">@v</option>
                        }
                    </select>
                </div>
            </div>

            <div class="am-form-actions">
                <a class="badge am-link-plain" href="/swines">Cancelar</a>
                <button type="submit" class="badge am-button-action">Salvar</button>
            </div>
        </form>
    </section>

    <footer class="footer-info">
        <span>Após salvar, você volta para a listagem.</span>
        <span>AgroManager</span>
    </footer>
</div>
</div>
